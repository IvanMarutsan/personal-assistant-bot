NODE_ENV=development
BOT_TOKEN=
# Public HTTPS Mini App URL used by Telegram Open App button.
# Stable testing: use hosted URL (e.g. Vercel domain).
# Local phone debug only: temporarily use tunnel URL.
MINI_APP_URL=https://mini-app.example.com
# Optional explicit edge URL. If empty, bot derives it from SUPABASE_URL.
EDGE_BASE_URL=
# Shared secret header for ingest-voice-telegram
BOT_INGEST_TOKEN=
# Publishable/anon key only (not service role key)
SUPABASE_ANON_KEY=
# Optional in pure scaffold mode. Required to store captures in Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LOG_LEVEL=info
